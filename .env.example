# ============================================
# OpenLabel Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================

# Supabase Configuration
SUPABASE_URL=######################
SUPABASE_ANON_KEY=#################
SUPABASE_SERVICE_ROLE_KEY=###############

# Google Gemini AI

# and in Render env vars; rotate if you ever exposed a key publicly.
GEMINI_API_KEY=

# Optional: override Gemini model (read by `ai_logic/llm_service.py` and vision)
GEMINI_MODEL=gemini-2.5-flash

# Optional: Google Cloud Vision auth (if using GCP Vision OCR path)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: OCR fallback behavior
# OPENLABEL_SKIP_VISION=1  (forces Tesseract-only OCR; no GCP calls)
OPENLABEL_SKIP_VISION=0

# Optional: set custom Tesseract binary path on Windows
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=

# Optional: data.gov.in mandi price records enrichment
# DATA_GOV_IN_API_KEY=...
# DATA_GOV_IN_RESOURCE_ID=...
DATA_GOV_IN_API_KEY=
DATA_GOV_IN_RESOURCE_ID=

# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# CORS — Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,*
